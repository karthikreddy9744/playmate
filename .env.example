# PlayMate Environment Configuration
# Copy this file to .env and fill in your actual values

# ========================
# DATABASE (Supabase PostgreSQL)
# ========================

# Supabase pooler connection (used by Spring Boot)
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-ap-south-1.pooler.supabase.com:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres.your-project-ref
SPRING_DATASOURCE_PASSWORD=your-supabase-password

# ========================
# AUTHENTICATION & SECURITY
# ========================

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-here-change-in-production
JWT_EXPIRATION=3600000

# ========================
# CLOUD SERVICES
# ========================

# Firebase (backend uses project ID; frontend uses full config)
FIREBASE_PROJECT_ID=your-project-id

# Cloudinary Image Storage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Redis (OTP caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ========================
# EMAIL & NOTIFICATIONS
# ========================

# Brevo (Sendinblue) Email Service
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@playmate.com
BREVO_SENDER_NAME=PlayMate

# ========================
# MESSAGE ENCRYPTION
# ========================

# AES-256-GCM key for message encryption at rest (Base64-encoded 32-byte key)
# Generate with: openssl rand -base64 32
PLAYMATE_MSG_ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# ========================
# APPLICATION SETTINGS
# ========================

# Server Port
BACKEND_PORT=8080

# CORS — comma-separated origins allowed to call the backend
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000